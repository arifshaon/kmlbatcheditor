+    private void ClearPlacemarkVisualPreview()
+    {
+        _previewPlacemarkIndex = 0;
+        PlacemarkVisualPreview = null;
+        OnPropertyChanged(nameof(PreviewPlacemarkPosition));
+    }
+
+    private void BuildPlacemarkVisualPreview()
+    {
+        if (_documentContext is null ||
+            _currentSelection.Count == 0 ||
+            _previewPlacemarkIndex < 0 ||
+            _previewPlacemarkIndex >= _currentSelection.Count)
+        {
+            ClearPlacemarkVisualPreview();
+            return;
+        }
+
+        try
+        {
+            PlacemarkVisualPreview = _previewService.Build(
+                _currentSelection[_previewPlacemarkIndex],
+                _documentContext,
+                EditSettings);
+
+            OnPropertyChanged(nameof(PreviewPlacemarkPosition));
+            PreviousPreviewPlacemarkCommand.RaiseCanExecuteChanged();
+            NextPreviewPlacemarkCommand.RaiseCanExecuteChanged();
+            OpenPreviewInGoogleEarthCommand.RaiseCanExecuteChanged();
+        }
+        catch (Exception ex)
+        {
+            ClearPlacemarkVisualPreview();
+            ShowNotification(
+                $"The style operation can still be reviewed, but the visual preview could not be created: {ex.Message}",
+                NotificationKind.Warning);
+        }
+    }
+
+    private void MovePreviewPlacemark(int offset)
+    {
+        if (!HasPlacemarkVisualPreview || _currentSelection.Count == 0)
+            return;
+
+        var nextIndex = Math.Clamp(
+            _previewPlacemarkIndex + offset,
+            0,
+            _currentSelection.Count - 1);
+
+        if (nextIndex == _previewPlacemarkIndex)
+            return;
+
+        _previewPlacemarkIndex = nextIndex;
+        BuildPlacemarkVisualPreview();
+    }
+
+    private async Task OpenPreviewInGoogleEarthAsync()
+    {
+        if (_documentContext is null ||
+            PlacemarkVisualPreview is null ||
+            _currentSelection.Count == 0 ||
+            _previewPlacemarkIndex >= _currentSelection.Count)
+        {
+            return;
+        }
+
+        var sourcePlacemark = _currentSelection[_previewPlacemarkIndex];
+        var visualPreview = PlacemarkVisualPreview;
+        string? previewPath = null;
+
+        var completed = await RunBusyOperationAsync(
+            title: "Creating Google Earth preview",
+            initialMessage: "Building a temporary one-placemark KMZ...",
+            canCancel: false,
+            operation: async (progress, _) =>
+            {
+                progress.Report(new OperationProgress(
+                    "Creating Google Earth preview...",
+                    visualPreview.PlacemarkName,
+                    35));
+
+                previewPath = await Task.Run(
+                    () => _googleEarthPreviewService.CreatePreviewKmz(
+                        sourcePlacemark,
+                        visualPreview));
+
+                progress.Report(new OperationProgress(
+                    "Preview package ready.",
+                    Path.GetFileName(previewPath),
+                    100));
+            });
+
+        if (!completed || string.IsNullOrWhiteSpace(previewPath))
+            return;
+
+        try
+        {
+            Process.Start(new ProcessStartInfo
+            {
+                FileName = previewPath,
+                UseShellExecute = true
+            });
+
+            StatusText = "Opened the proposed placemark appearance in Google Earth.";
+            ShowNotification(
+                "The temporary preview was sent to the application associated with KMZ files.",
+                NotificationKind.Success);
+        }
+        catch (Exception ex)
+        {
+            ShowNotification(
+                $"The preview KMZ was created, but Windows could not open it: {ex.Message}",
+                NotificationKind.Error);
+        }
+    }
