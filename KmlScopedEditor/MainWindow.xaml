<Window x:Class="KmlScopedEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KmlScopedEditor.ViewModels"
        xmlns:models="clr-namespace:KmlScopedEditor.Models"
        mc:Ignorable="d"
        Title="KML Scoped Editor"
        Height="800"
        Width="1300"
        MinHeight="650"
        MinWidth="1050">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter
            x:Key="BooleanToVisibilityConverter" />

        <HierarchicalDataTemplate
            DataType="{x:Type models:KmlTreeNode}"
            ItemsSource="{Binding Children}">

            <Grid Margin="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          IsThreeState="True"
                          IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Top"
                          Margin="0,2,6,0" />

                <TextBlock Grid.Column="1"
                           Margin="0,1,6,0"
                           FontSize="14">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="📄" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NodeType}" Value="Folder">
                                    <Setter Property="Text" Value="📁" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NodeType}" Value="Document">
                                    <Setter Property="Text" Value="🗂" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NodeType}" Value="Placemark">
                                    <Setter Property="Text" Value="📍" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NodeType}" Value="GroundOverlay">
                                    <Setter Property="Text" Value="🖼" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NodeType}" Value="NetworkLink">
                                    <Setter Property="Text" Value="🔗" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding Name}"
                               FontSize="14"
                               Foreground="#1F3A93" />
                    <TextBlock Text="{Binding Subtitle}"
                               FontSize="12"
                               Foreground="Gray"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="520" />
                </StackPanel>
            </Grid>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <DockPanel IsEnabled="{Binding IsNotBusy}">
        <Border DockPanel.Dock="Top"
                Background="#F2F2F2"
                Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="Open KML/KMZ"
                        Width="125"
                        Height="30"
                        Command="{Binding OpenKmlCommand}" />

                <Button Content="Save As"
                        Width="100"
                        Height="30"
                        Margin="8,0,0,0"
                        Command="{Binding SaveAsCommand}" />

                <TextBlock Margin="12,7,0,0"
                           Text="{Binding LoadedFilePath}"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Margin="12,7,0,0"
                           Text="{Binding UnsavedChangesDisplay}"
                           Foreground="#B42318"
                           FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top"
                Visibility="{Binding HasNotification, Converter={StaticResource BooleanToVisibilityConverter}}"
                Padding="12,9"
                BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#EAF2FF" />
                    <Setter Property="BorderBrush" Value="#9ABCF0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NotificationKind}"
                                     Value="{x:Static models:NotificationKind.Success}">
                            <Setter Property="Background" Value="#E9F7EF" />
                            <Setter Property="BorderBrush" Value="#85C99C" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NotificationKind}"
                                     Value="{x:Static models:NotificationKind.Warning}">
                            <Setter Property="Background" Value="#FFF6DF" />
                            <Setter Property="BorderBrush" Value="#E3BA5B" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NotificationKind}"
                                     Value="{x:Static models:NotificationKind.Error}">
                            <Setter Property="Background" Value="#FDECEC" />
                            <Setter Property="BorderBrush" Value="#D99A9A" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Command="{Binding DismissNotificationCommand}"
                        Width="28"
                        Height="24"
                        Margin="12,0,0,0"
                        ToolTip="Dismiss notification" />

                <TextBlock Text="{Binding NotificationText}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold" />
            </DockPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#D0D0D0"
                    BorderThickness="0,0,1,0"
                    Background="#FAFAFA">
                <TreeView ItemsSource="{Binding RootNodes}"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded"
                                    Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="IsSelected"
                                    Value="{Binding IsSelected, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <Border Visibility="{Binding HasLoadSummary, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,20"
                            Padding="14"
                            Background="#EEF6FF"
                            BorderBrush="#A9C8E8"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="File loaded successfully"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding LoadSummaryText}"
                                       TextWrapping="Wrap"
                                       LineHeight="20" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Selection Details"
                               FontSize="22"
                               FontWeight="SemiBold" />

                    <Border Margin="0,12,0,20"
                            Padding="12"
                            Background="#F7F7F7"
                            CornerRadius="6">
                        <TextBlock Text="{Binding SelectedNodeSummary}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Style Diagnostics"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />

                    <TextBlock Text="{Binding StyleDiagnosticsMessage}"
                               Foreground="Gray"
                               Margin="0,0,0,10" />

                    <Border Padding="12"
                            Margin="0,0,0,20"
                            Background="#FCFCFC"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Style source:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding SelectedStyle.StyleSource}"
                                       Margin="0,3"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="styleUrl:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding SelectedStyle.StyleUrlDisplay}"
                                       Margin="0,3"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Normal style:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding SelectedStyle.NormalStyleUrlDisplay}"
                                       Margin="0,3"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Highlight style:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding SelectedStyle.HighlightStyleUrlDisplay}"
                                       Margin="0,3"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Inline style:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding SelectedStyle.InlineStyleDisplay}"
                                       Margin="0,3" />

                            <TextBlock Grid.Row="5" Grid.Column="0"
                                       Text="Icon URL:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="5" Grid.Column="1"
                                       Text="{Binding SelectedStyle.IconHrefDisplay}"
                                       Margin="0,3"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="Icon size:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="6" Grid.Column="1"
                                       Text="{Binding SelectedStyle.IconScaleDisplay}"
                                       Margin="0,3" />

                            <TextBlock Grid.Row="7" Grid.Column="0"
                                       Text="Icon color:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="7" Grid.Column="1"
                                       Text="{Binding SelectedStyle.IconColorDisplay}"
                                       Margin="0,3"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="8" Grid.Column="0"
                                       Text="Text size:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="8" Grid.Column="1"
                                       Text="{Binding SelectedStyle.LabelScaleDisplay}"
                                       Margin="0,3" />

                            <TextBlock Grid.Row="9" Grid.Column="0"
                                       Text="Text color:"
                                       FontWeight="SemiBold"
                                       Margin="0,3" />
                            <TextBlock Grid.Row="9" Grid.Column="1"
                                       Text="{Binding SelectedStyle.LabelColorDisplay}"
                                       Margin="0,3"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <TextBlock Text="Placemark Selection"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <Border Padding="12"
                            Margin="0,0,0,20"
                            Background="#FCFCFC"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6">

                        <StackPanel>
                            <TextBlock Text="Select placemarks by"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5" />

                            <ComboBox ItemsSource="{Binding SelectionModes}"
                                      SelectedItem="{Binding SelectedSelectionMode}"
                                      DisplayMemberPath="Label"
                                      Width="260"
                                      HorizontalAlignment="Left"
                                      Margin="0,0,0,14" />

                            <StackPanel Visibility="{Binding IsFolderSelectionMode,
                                Converter={StaticResource BooleanToVisibilityConverter}}">

                                <TextBlock Text="Current tree selection"
                                           FontWeight="SemiBold" />

                                <TextBlock Text="{Binding SelectedNode.Name}"
                                           Margin="0,3,0,10"
                                           Foreground="#1F3A93"
                                           TextWrapping="Wrap" />

                                <CheckBox Content="Include placemarks in nested subfolders"
                                          IsChecked="{Binding IncludeSubfolders}"
                                          Margin="0,0,0,14" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsIconTypeSelectionMode,
                                Converter={StaticResource BooleanToVisibilityConverter}}">

                                <TextBlock Text="{Binding IconSelectionPrompt}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />

                                <ListBox ItemsSource="{Binding IconTypes}"
                                         Height="260"
                                         Margin="0,0,0,14"
                                         HorizontalContentAlignment="Stretch"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling">

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}"
                                                      ToolTip="{Binding IconHref}"
                                                      Padding="2"
                                                      HorizontalContentAlignment="Stretch">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <TextBlock Text="{Binding DetailText}"
                                                               Foreground="Gray"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="620" />
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <Button Content="Calculate Selection"
                                    Command="{Binding CalculateSelectionCommand}"
                                    Width="160"
                                    Height="32"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,12" />

                            <Border Background="#F2F6FC"
                                    BorderBrush="#CBD8EA"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="{Binding MatchedPlacemarkCount,
                                        StringFormat={}{0:N0} matched placemarks}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />

                                    <TextBlock Text="{Binding SelectionSummary}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Batch Style Edit"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <Border Padding="12"
                            Background="#FCFCFC"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="Enable only the properties that should change. Unchecked properties will remain untouched."
                                       Foreground="Gray"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="185" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0"
                                          Grid.Column="0"
                                          Content="Change icon size"
                                          IsChecked="{Binding EditSettings.ChangeIconScale}"
                                          Margin="0,5,10,5" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Text="{Binding EditSettings.IconScaleText, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding EditSettings.ChangeIconScale}"
                                         Margin="0,3,0,3"
                                         Padding="5"
                                         ToolTip="KML scale, for example 0.8, 1 or 1.5" />

                                <CheckBox Grid.Row="1"
                                          Grid.Column="0"
                                          Content="Change icon color"
                                          IsChecked="{Binding EditSettings.ChangeIconColor}"
                                          Margin="0,5,10,5" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Text="{Binding EditSettings.IconColorText, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding EditSettings.ChangeIconColor}"
                                         Margin="0,3,6,3"
                                         Padding="5"
                                         ToolTip="Use #RRGGBB or #AARRGGBB" />
                                <Button Grid.Row="1"
                                        Grid.Column="2"
                                        Content="Choose..."
                                        Command="{Binding PickIconColorCommand}"
                                        IsEnabled="{Binding EditSettings.ChangeIconColor}"
                                        MinWidth="78"
                                        Margin="0,3,0,3" />

                                <CheckBox Grid.Row="2"
                                          Grid.Column="0"
                                          Content="Change text size"
                                          IsChecked="{Binding EditSettings.ChangeLabelScale}"
                                          Margin="0,5,10,5" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Text="{Binding EditSettings.LabelScaleText, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding EditSettings.ChangeLabelScale}"
                                         Margin="0,3,0,3"
                                         Padding="5"
                                         ToolTip="KML label scale, for example 0.8, 1 or 1.5" />

                                <CheckBox Grid.Row="3"
                                          Grid.Column="0"
                                          Content="Change text color"
                                          IsChecked="{Binding EditSettings.ChangeLabelColor}"
                                          Margin="0,5,10,5" />
                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Text="{Binding EditSettings.LabelColorText, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding EditSettings.ChangeLabelColor}"
                                         Margin="0,3,6,3"
                                         Padding="5"
                                         ToolTip="Use #RRGGBB or #AARRGGBB" />
                                <Button Grid.Row="3"
                                        Grid.Column="2"
                                        Content="Choose..."
                                        Command="{Binding PickLabelColorCommand}"
                                        IsEnabled="{Binding EditSettings.ChangeLabelColor}"
                                        MinWidth="78"
                                        Margin="0,3,0,3" />
                            </Grid>

                            <TextBlock Text="Colors may be entered as #RRGGBB or #AARRGGBB. The app converts them to KML AABBGGRR format automatically."
                                       Foreground="Gray"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,14" />

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,12">
                                <Button Content="Preview Changes"
                                        Command="{Binding PreviewChangesCommand}"
                                        Width="145"
                                        Height="32" />

                                <Button Content="Apply Changes"
                                        Command="{Binding ApplyChangesCommand}"
                                        Width="135"
                                        Height="32"
                                        Margin="8,0,0,0" />
                            </StackPanel>

                            <Border Background="#F8F9FB"
                                    BorderBrush="#D9DEE7"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="4">
                                <TextBlock Text="{Binding BatchEditMessage}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        </DockPanel>

        <Border Panel.ZIndex="100"
                Background="#99000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Border Width="500"
                        MaxWidth="700"
                        Padding="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="White"
                        BorderBrush="#C8CDD5"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="{Binding BusyTitle}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="{Binding BusyMessage}"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <ProgressBar Height="18"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding BusyProgress,
                                                     Mode=OneWay,
                                                     FallbackValue=0,
                                                     TargetNullValue=0}"
                                     IsIndeterminate="{Binding IsBusyProgressIndeterminate}"
                                     Margin="0,0,0,10" />

                        <TextBlock Text="{Binding BusyDetail}"
                                   Foreground="#5E6673"
                                   TextWrapping="Wrap"
                                   MinHeight="18"
                                   Margin="0,0,0,16" />

                        <Button Content="Cancel"
                                Command="{Binding CancelOperationCommand}"
                                Visibility="{Binding CanCancelCurrentOperation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Width="100"
                                Height="32"
                                HorizontalAlignment="Right" />

                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
