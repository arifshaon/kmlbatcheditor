<UserControl x:Class="KmlScopedEditor.Views.PlacemarkNameSelectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:KmlScopedEditor.Models">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedSelectionMode.Value}"
                             Value="{x:Static models:PlacemarkSelectionMode.PlacemarkName}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <StackPanel Margin="0,0,0,14">
        <TextBlock Text="Select placemarks by name"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5" />

        <TextBlock Text="Search is case-insensitive and uses partial matching by default. Check the exact names that should be modified."
                   Foreground="Gray"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding PlacemarkNameSearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6"
                     ToolTip="Type part of a placemark name" />

            <CheckBox Grid.Column="1"
                      Content="Exact search match only"
                      IsChecked="{Binding PlacemarkNameExactMatchOnly}"
                      VerticalAlignment="Center"
                      Margin="10,0,0,0" />
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Select visible"
                    Command="{Binding SelectVisiblePlacemarkNamesCommand}"
                    MinWidth="100"
                    Height="28" />
            <Button Content="Clear all"
                    Command="{Binding ClearPlacemarkNameSelectionsCommand}"
                    MinWidth="90"
                    Height="28"
                    Margin="6,0,0,0" />
            <TextBlock Text="{Binding PlacemarkNameSearchSummary}"
                       Foreground="#52606D"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0" />
        </StackPanel>

        <ListBox ItemsSource="{Binding PlacemarkNameOptions}"
                 Height="260"
                 HorizontalContentAlignment="Stretch"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}"
                              Padding="2"
                              HorizontalContentAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CountDisplay}"
                                       Foreground="Gray"
                                       Margin="12,0,4,0" />
                        </Grid>
                    </CheckBox>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</UserControl>
